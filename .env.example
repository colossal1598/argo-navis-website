# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it contains secret keys.

# Found in your Supabase project:  Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Found in your Supabase project:  Settings → API Keys → API Keys tab → Secret key
# Format: sb_secret_...  (NOT the legacy service_role JWT key)
# Use the secret key (not publishable) so the API route can insert without RLS restrictions.
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Cloudflare Turnstile site key (safe for browser exposure)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudflare Turnstile secret key (server-side only)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Resend — transactional email (lead auto-reply + owner notification)
# Get your key at resend.com → API Keys
RESEND_API_KEY=re_your-api-key-here

# Inbox where owner lead-alert emails are delivered
NOTIFICATION_EMAIL=your@email.com
