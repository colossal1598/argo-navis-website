# Copy this file to .env and fill in your values.
# NEVER commit the real .env file — it contains secret keys.

# Found in your Supabase project:  Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Found in your Supabase project:  Settings → API → service_role (secret)
# Use service_role (not anon) so the API route can insert without RLS restrictions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Turnstile site key (safe for browser exposure)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudflare Turnstile secret key (server-side only)
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
