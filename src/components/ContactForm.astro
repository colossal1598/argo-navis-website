---
/*
  PROPS:
    heading      — title shown above the form
    subheading   — one-line description under the title
    source       — tag stored in the database so you know which page
                   the lead came from (e.g. "landing", "websites")
    fields       — array of form field configs (see default below)
                   override per-page to change what the form asks
    submitLabel  — text on the submit button (default: "Let's talk")
    reassurance  — small muted line under the button
                   e.g. "No pitch. No pressure. Just a conversation."
*/

interface FieldConfig {
  id:          string;
  label:       string;
  type:        "text" | "email" | "url" | "textarea";
  placeholder: string;
  required:    boolean;
}

interface Props {
  heading?:     string;
  subheading?:  string;
  source?:      string;
  fields?:      FieldConfig[];
  submitLabel?: string;
  reassurance?: string;
  loadingText?: string;
  successText?: string;
  turnstileHint?: string;
  challengeErrorText?: string;
  contactMethodLabel?: string;
  contactMethods?: ContactMethodConfig[];
  contactDetailsRequiredText?: string;
  contactDetailsPlaceholders?: Partial<Record<ContactMethodConfig["id"], string>>;
}

interface ContactMethodConfig {
  id: "whatsapp" | "telegram" | "phone" | "email";
  label: string;
}

/*
  DEFAULT FIELDS — used on the homepage.
  Pages that need different fields pass their own array via the
  fields prop (see websites/index.astro for an example).
*/
const defaultFields: FieldConfig[] = [
  {
    id:          "name",
    label:       "Your name",
    type:        "text",
    placeholder: "Your name",
    required:    true,
  },
  {
    id:          "email",
    label:       "Email",
    type:        "email",
    placeholder: "you@company.com",
    required:    true,
  },
  {
    id:          "website",
    label:       "Website",
    type:        "url",
    placeholder: "yoursite.com (if you have one)",
    required:    false,
  },
  {
    id:          "message",
    label:       "What do you need?",
    type:        "textarea",
    placeholder: "Tell us what's going on",
    required:    true,
  },
];

const defaultContactMethods: ContactMethodConfig[] = [
  { id: "email", label: "Email" },
  { id: "phone", label: "Phone" },
  { id: "telegram", label: "Telegram" },
  { id: "whatsapp", label: "WhatsApp" },
];

const defaultContactDetailsPlaceholders: Record<ContactMethodConfig["id"], string> = {
  email: "",
  phone: "Your phone number (with country code)",
  telegram: "Your Telegram @username",
  whatsapp: "Your WhatsApp number (with country code)",
};

const contactMethodIcons = {
  whatsapp: "whatsapp",
  telegram: "telegram",
  phone: "phone",
  email: "email",
} as const;

const methodNeedsDetails = {
  email: false,
  phone: true,
  telegram: true,
  whatsapp: true,
} as const;

const methodDetailsRequired = "Contact details are required for this contact method.";

const {
  heading     = "Ready to stop leaving money on the table?",
  subheading  = "Tell us what you're working with. We'll take it from there.",
  source      = "landing",
  fields      = defaultFields,
  submitLabel = "Let's talk",
  reassurance = "No pitch. No pressure. Just a conversation.",
  loadingText = "Sending...",
  successText = "Got it — we'll be in touch.",
  turnstileHint = "Bot protection is not configured yet.",
  challengeErrorText = "Please complete the verification challenge.",
  contactMethodLabel = "Preferred contact method",
  contactMethods = defaultContactMethods,
  contactDetailsRequiredText = methodDetailsRequired,
  contactDetailsPlaceholders = defaultContactDetailsPlaceholders,
} = Astro.props;

const normalizedContactMethods = contactMethods;
const mergedContactDetailsPlaceholders = {
  ...defaultContactDetailsPlaceholders,
  ...(contactDetailsPlaceholders ?? {}),
};
const defaultContactMethod = normalizedContactMethods[0]?.id ?? "email";
const defaultMethodNeedsDetails = methodNeedsDetails[defaultContactMethod];

const contactMethodMeta = normalizedContactMethods.map((method) => ({
  id: method.id,
  label: method.label,
  icon: contactMethodIcons[method.id],
  detailsPlaceholder: mergedContactDetailsPlaceholders[method.id],
}));

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? "";
const turnstileRequired = import.meta.env.PROD;
---

<section id="contact" class="bg-surface-950 px-6 py-24">
  <div class="mx-auto max-w-xl">

    <!-- Heading — left-aligned to feel less like a marketing push -->
    <div class="mb-10">
      <h2 class="text-3xl font-bold text-text-primary">{heading}</h2>
      {subheading && <p class="mt-3 text-text-muted">{subheading}</p>}
    </div>

    <!--
      THE FORM — lightweight, no heavy card or box around it.
      Inputs sit directly on the page background for a clean feel.
    -->
    <form id="lead-form" novalidate class="space-y-6">

      <!-- Hidden source tag — automatic, no need to touch -->
      <input type="hidden" name="source" value={source} />
      <input type="hidden" id="contact-method-input" name="contact_method" value={defaultContactMethod} />

      {fields.map(field => (
        <div>
          <label for={field.id} class="mb-1.5 block text-sm font-medium text-text-soft">
            {field.label}
            {field.required && <span class="ms-1 text-brand-400">*</span>}
          </label>

          {field.type === "textarea" ? (
            <textarea
              id={field.id}
              name={field.id}
              placeholder={field.placeholder}
              required={field.required}
              rows={5}
              class="w-full border-b border-border-subtle bg-transparent px-0 py-3 text-sm text-text-primary placeholder:text-text-muted/70 focus:border-brand-500 focus:outline-none"
            />
          ) : (
            <input
              type={field.type}
              id={field.id}
              name={field.id}
              placeholder={field.placeholder}
              required={field.required}
              class="w-full border-b border-border-subtle bg-transparent px-0 py-3 text-sm text-text-primary placeholder:text-text-muted/70 focus:border-brand-500 focus:outline-none"
            />
          )}
        </div>
      ))}

      <!--
        CONTACT METHOD BUTTONS — one selected value is stored in hidden input.
        Keep this list short so selection is quick on mobile.
      -->
      <div>
        <p class="mb-2 block text-sm font-medium text-text-soft">{contactMethodLabel}</p>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
          {contactMethodMeta.map((method, index) => (
            <button
              type="button"
              data-contact-method={method.id}
              class:list={[
                "contact-method-btn inline-flex items-center justify-center gap-2 rounded-md border border-border-subtle px-3 py-2 text-xs font-medium text-text-muted transition-colors hover:border-brand-500/60 hover:text-text-primary",
                index === 0 && "border-brand-500/60 text-text-primary",
              ]}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              {method.icon === "whatsapp" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20 11.8a8 8 0 0 1-11.8 7L4 20l1.4-4A8 8 0 1 1 20 11.8zm-8-6.3a6.3 6.3 0 0 0-5.4 9.5l.2.3-.8 2.4 2.5-.8.2.1A6.3 6.3 0 1 0 12 5.5zm3.4 8c-.2-.1-1.3-.6-1.5-.7-.2-.1-.4-.1-.5.1-.1.2-.6.7-.7.8-.1.1-.3.1-.5 0a5.2 5.2 0 0 1-1.5-.9 5.8 5.8 0 0 1-1.1-1.3c-.1-.2 0-.3.1-.4l.3-.4.2-.3c.1-.1 0-.3 0-.4l-.7-1.6c-.2-.4-.3-.3-.5-.3h-.4c-.1 0-.4 0-.6.3s-.8.7-.8 1.8.8 2.1.9 2.2c.1.1 1.6 2.5 4 3.4.5.2.8.3 1.1.4.5.1 1 .1 1.4.1.4-.1 1.3-.5 1.5-1s.2-.9.1-1-.2-.2-.4-.3z" />
                </svg>
              )}
              {method.icon === "telegram" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M21.5 4.6c.3-1.2-.5-1.7-1.5-1.3L3.5 9.6c-1.1.4-1.1 1 .2 1.4l4.2 1.3 9.7-6.1c.5-.3.9-.1.5.2l-7.9 7.1-.3 4.6c.4 0 .6-.2.9-.4l2.1-2 4.4 3.3c.8.4 1.4.2 1.6-.8l2.6-12.6z" />
                </svg>
              )}
              {method.icon === "phone" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M22 16.9v3a2 2 0 0 1-2.2 2A19.8 19.8 0 0 1 11.2 19a19.4 19.4 0 0 1-6-6 19.8 19.8 0 0 1-2.9-8.6A2 2 0 0 1 4.2 2h3a2 2 0 0 1 2 1.7c.1.9.4 1.8.8 2.6a2 2 0 0 1-.4 2l-1.2 1.2a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2-.4c.8.4 1.7.7 2.6.8A2 2 0 0 1 22 16.9z" />
                </svg>
              )}
              {method.icon === "email" && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" />
                  <path d="M3 7l9 6 9-6" />
                </svg>
              )}
              <span>{method.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Contact details field appears for non-email methods -->
      <div id="contact-details-wrap" class:list={[!defaultMethodNeedsDetails && "hidden"]}>
        <input
          id="contact-details-input"
          name="contact_details"
          type="text"
          value=""
          placeholder={contactMethodMeta.find(m => m.id === defaultContactMethod)?.detailsPlaceholder}
          required={defaultMethodNeedsDetails}
          class="w-full border-b border-border-subtle bg-transparent px-0 py-3 text-sm text-text-primary placeholder:text-text-muted/70 focus:border-brand-500 focus:outline-none"
        />
      </div>

      <div class="space-y-2">
        {turnstileSiteKey ? (
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-theme="auto"
          ></div>
        ) : (
          <p class="text-sm text-text-muted">
            {turnstileHint}
          </p>
        )}
      </div>

      <!-- Error box — shown by JS on API error -->
      <p id="form-error" class="hidden text-sm text-red-400"></p>

      <div>
        <!--
          SUBMIT BUTTON — sharp corners (rounded-sm), same style
          as the hero CTA for consistency across the page.
        -->
        <button
          type="submit"
          id="submit-btn"
          class="rounded-sm bg-brand-500 px-8 py-4 text-base font-semibold text-white transition-colors hover:bg-brand-400 disabled:cursor-not-allowed disabled:opacity-50"
        >
          {submitLabel}
        </button>

        <!--
          REASSURANCE LINE — small muted text under the button.
          Change via the reassurance prop. Delete the line in the
          prop if you don't want it.
        -->
        {reassurance && (
          <p class="mt-3 text-sm text-text-muted">{reassurance}</p>
        )}
      </div>

    </form>

    <!-- Success message — revealed by JS after a 200 response -->
    <div id="form-success" class="hidden mt-6">
      <p class="text-lg font-semibold text-text-primary">{successText}</p>
    </div>

  </div>
</section>

{turnstileSiteKey && (
  <script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
)}

<script define:vars={{ loadingText, submitLabel, turnstileRequired, challengeErrorText, contactDetailsRequiredText, methodNeedsDetails, mergedContactDetailsPlaceholders }}>
  const form       = document.getElementById("lead-form");
  const btn        = document.getElementById("submit-btn");
  const errorBox   = document.getElementById("form-error");
  const successBox = document.getElementById("form-success");
  const contactMethodInput = document.getElementById("contact-method-input");
  const contactMethodButtons = document.querySelectorAll(".contact-method-btn");
  const contactDetailsWrap = document.getElementById("contact-details-wrap");
  const contactDetailsInput = document.getElementById("contact-details-input");

  function applyContactMethodState(method) {
    const needsDetails = Boolean(methodNeedsDetails?.[method]);
    if (!contactDetailsWrap || !contactDetailsInput) return;

    contactDetailsWrap.classList.toggle("hidden", !needsDetails);
    contactDetailsInput.required = needsDetails;
    contactDetailsInput.placeholder = mergedContactDetailsPlaceholders?.[method] ?? "";

    if (!needsDetails) {
      contactDetailsInput.value = "";
    }
  }

  // Sync visible selected button with hidden input value sent to the API.
  contactMethodButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const method = button.getAttribute("data-contact-method");
      if (!method || !contactMethodInput) return;

      contactMethodInput.value = method;
      applyContactMethodState(method);
      contactMethodButtons.forEach((btnEl) => {
        btnEl.classList.remove("border-brand-500/60", "text-text-primary");
        btnEl.classList.add("border-border-subtle", "text-text-muted");
        btnEl.setAttribute("aria-pressed", "false");
      });
      button.classList.add("border-brand-500/60", "text-text-primary");
      button.classList.remove("border-border-subtle", "text-text-muted");
      button.setAttribute("aria-pressed", "true");
    });
  });

  if (contactMethodInput?.value) {
    applyContactMethodState(contactMethodInput.value);
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    btn.disabled    = true;
    btn.textContent = loadingText;
    errorBox.classList.add("hidden");

    const formData = new FormData(form);
    const token = formData.get("cf-turnstile-response");
    const selectedMethod = String(formData.get("contact_method") ?? "email");
    const methodDetail = String(formData.get("contact_details") ?? "").trim();

    if (selectedMethod !== "email" && !methodDetail) {
      errorBox.textContent = contactDetailsRequiredText;
      errorBox.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = submitLabel;
      return;
    }

    if (!token && turnstileRequired) {
      errorBox.textContent = challengeErrorText;
      errorBox.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = submitLabel;
      return;
    }

    const data = Object.fromEntries(formData);

    try {
      const res  = await fetch("/api/leads", {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(data),
      });
      const json = await res.json();

      if (res.ok) {
        form.classList.add("hidden");
        successBox.classList.remove("hidden");
      } else {
        errorBox.textContent = json.error ?? "Something went wrong.";
        errorBox.classList.remove("hidden");
        btn.disabled    = false;
        btn.textContent = submitLabel;
        const turnstileApi = globalThis.turnstile;
        if (turnstileApi && typeof turnstileApi.reset === "function") {
          turnstileApi.reset();
        }
      }
    } catch {
      errorBox.textContent = "Network error — please try again.";
      errorBox.classList.remove("hidden");
      btn.disabled    = false;
      btn.textContent = submitLabel;
      const turnstileApi = globalThis.turnstile;
      if (turnstileApi && typeof turnstileApi.reset === "function") {
        turnstileApi.reset();
      }
    }
  });
</script>
