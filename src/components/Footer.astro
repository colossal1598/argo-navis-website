---
import { type SiteLocale, withLocale } from "../lib/locale";

interface Props {
  locale?: SiteLocale;
}

const { locale = "en" } = Astro.props;
const isHebrew = locale === "he";

/*
  FOOTER COLUMNS — each object is a column in the footer.
  To add a column: add another { heading, links: [...] } object.
  To add a link inside a column: add { label, href } to its links array.
*/
const columns = [
  {
    heading: isHebrew ? "שירותים" : "Services",
    links: [
      { label: isHebrew ? "אוטומציות" : "Automations", href: withLocale("/automations", locale) },
      { label: isHebrew ? "אתרים" : "Websites", href: withLocale("/websites", locale) },
      { label: isHebrew ? "קמפיינים" : "Campaigns", href: withLocale("/campaigns", locale) },
    ],
  },
  {
    heading: isHebrew ? "חברה" : "Company",
    links: [
      { label: isHebrew ? "דברו איתנו" : "Contact", href: withLocale("/#contact", locale) },
    ],
  },
];

/*
  SOCIAL LINKS — add/remove social platforms here.
  Icons are simple SVG paths; swap them out if you change a platform.
*/
const socials = [
  { label: "LinkedIn", href: "https://linkedin.com", icon: "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" },
];

/* LEGAL TEXT — change the year or company name */
const year = new Date().getFullYear();
const companyName = "Argo Navis";
---

<footer class="border-t border-border-subtle bg-surface-900">
  <div class="mx-auto max-w-6xl px-6 py-12">

    <!-- Top row: logo + columns -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a href={withLocale("/", locale)} class="text-xl font-bold text-text-primary">
          Argo <span class="text-brand-400">Navis</span>
        </a>
        <!--
          TAGLINE — one sentence that captures what you do.
          Keep it under ~12 words for best readability.
        -->
        <p class="mt-3 max-w-xs text-sm text-text-muted">
          {isHebrew
            ? "אנחנו בונים מערכות, אתרים וקמפיינים שמביאים לידים ומקדמים את העסק שלכם."
            : "We build systems, sites, and campaigns that generate leads and scale your business."}
        </p>

        <!-- Social icons -->
        <div class="mt-4 flex gap-3">
          {socials.map(s => (
            <a
              href={s.href}
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-md p-2 text-text-muted transition-colors hover:bg-surface-700 hover:text-text-primary"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                <path d={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {columns.map(col => (
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted/80">
            {col.heading}
          </h3>
          <ul class="mt-3 space-y-2">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-muted transition-colors hover:text-text-primary"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom row: copyright -->
    <div class="mt-10 border-t border-border-subtle pt-6 text-center text-xs text-text-muted/80">
      © {year} {companyName}. All rights reserved.
    </div>

  </div>
</footer>
