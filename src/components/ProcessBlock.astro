---
/*
  PROPS:
    heading — section title shown above the steps
              defaults to "How it works"
    steps   — array of step objects:
                label       — bold step name
                description — one sentence, keep it short

  Used on the homepage (4 steps) and websites page (5 steps).
  Pass a different steps array to each page.
*/
interface Step {
  label:       string;
  description: string;
}

interface Props {
  heading?: string;
  steps:    Step[];
}

const { heading = "How it works", steps } = Astro.props;
---

<section class="bg-surface-950 px-6 py-24">
  <div class="mx-auto max-w-5xl">

    <!-- Section heading -->
    <h2 class="mb-12 text-center text-3xl font-bold text-text-primary md:text-4xl">
      {heading}
    </h2>

    <!--
      STEPS — horizontal on desktop (grid-cols-N), vertical on mobile.
      The connecting line sits behind the numbered circles on md+.
    -->
    <div class="relative">

      <!--
        CONNECTING LINE — only visible on md+ screens.
        hidden md:block — invisible on mobile where steps stack vertically.
      -->
      <div
        class="absolute start-0 end-0 top-5 hidden h-px bg-border-subtle md:block"
        aria-hidden="true"
      ></div>

      <!--
        STEPS GRID — single column on mobile, N columns on md+.
        The md: inline style only applies at the md breakpoint and above
        via a wrapping <style> so mobile always gets a single column.
      -->
      <ol
        class="relative grid grid-cols-1 gap-10 md:gap-6"
        style={`--process-cols: ${steps.length}`}
      >
        {steps.map((step, i) => (
          <li class="flex flex-col items-center text-center">

            <!--
              NUMBER CIRCLE — sits on top of the connecting line (z-10).
              bg-surface-950 matches the page background so the line
              appears to "pass through" the circle gap.
            -->
            <div class="relative z-10 mb-4 flex h-10 w-10 items-center justify-center rounded-full border border-brand-500/30 bg-surface-950 text-sm font-bold text-brand-400">
              {i + 1}
            </div>

            <!-- STEP LABEL — bold -->
            <p class="font-semibold text-text-primary">{step.label}</p>

            <!-- STEP DESCRIPTION — one line -->
            <p class="mt-1 text-sm text-text-muted">{step.description}</p>

          </li>
        ))}
      </ol>
    </div>

  </div>
</section>

<style>
  @media (min-width: 768px) {
    ol[style*="--process-cols"] {
      grid-template-columns: repeat(var(--process-cols), 1fr);
    }
  }
</style>
