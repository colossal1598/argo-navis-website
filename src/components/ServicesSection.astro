---
/*
  PROPS:
    heading    — section title (default: "What we do")
    subheading — optional sub-copy line (leave empty to hide)
    services   — optional array to override the default EN service list.
                 Pass a localized array from Hebrew pages.

  SERVICE OBJECT:
    title       — name of the service
    description — one line that does the selling
    href        — link to the full service page
    cta         — text on the "learn more" link
    accent      — "brand" | "gold" | "slate"
*/

interface ServiceItem {
  title:       string;
  description: string;
  href:        string;
  cta:         string;
  accent:      string;
}

interface Props {
  heading?:    string;
  subheading?: string;
  services?:   ServiceItem[];
}

const defaultServices: ServiceItem[] = [
  {
    title:       "Websites",
    description: "Your site is your first impression. Make it count.",
    href:        "/websites",
    cta:         "Learn more",
    accent:      "gold",
  },
  {
    title:       "Campaigns",
    description: "Ads and content that bring people in, not just rack up impressions.",
    href:        "/campaigns",
    cta:         "Learn more",
    accent:      "brand",
  },
  {
    title:       "Automations",
    description: "Let the repetitive work run itself while you focus on growth.",
    href:        "/automations",
    cta:         "Learn more",
    accent:      "slate",
  },
];

const {
  heading    = "What we do",
  subheading = "",
  services   = defaultServices,
} = Astro.props;

/*
  ACCENT MAP — maps the accent string to a hover border color.
  All card links use text-brand-400 regardless of accent.
*/
const accentMap: Record<string, { border: string }> = {
  brand: { border: "hover:border-brand-500/40" },
  gold:  { border: "hover:border-gold-500/40"  },
  slate: { border: "hover:border-slate-500/40" },
};
---

<!--
  id="services" lets the CTA buttons on the Hero link to this section
  via href="/#services" — the page scrolls smoothly to here.
-->
<section id="services" class="bg-surface-950 px-6 py-20">
  <div class="mx-auto max-w-6xl">

    <!-- Section heading -->
    <div class:list={["text-center", subheading ? "mb-12" : "mb-10"]}>
      <h2 class="text-3xl font-bold text-text-primary md:text-4xl">{heading}</h2>
      {subheading && <p class="mx-auto mt-4 max-w-2xl text-text-muted">{subheading}</p>}
    </div>

    <!--
      CARD GRID — three columns on large screens, one column on mobile.
    -->
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {services.map(service => {
        const a = accentMap[service.accent] ?? accentMap.brand;
        return (
          <article class={`group relative flex flex-col rounded-2xl border border-border-subtle bg-surface-900 p-8 transition-all duration-200 hover:bg-surface-800 ${a.border}`}>

            <!-- Card title -->
            <h3 class="text-xl font-semibold text-text-primary">{service.title}</h3>

            <!-- Card description -->
            <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
              {service.description}
            </p>

            <!--
              CARD LINK — stretched-link pattern: the ::after pseudo-element
              covers the whole card so the entire card is clickable.
            -->
            <a
              href={service.href}
              class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-brand-400 transition-all after:absolute after:inset-0 after:rounded-2xl"
            >
              {service.cta}
              <svg class="icon-chevron h-4 w-4 transition-transform group-hover:translate-x-1 rtl:rotate-180 rtl:group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>

          </article>
        );
      })}
    </div>
  </div>
</section>
