---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { stripLocalePrefix, type SiteLocale, withLocale } from "../lib/locale";

/*
  PROPS — every page that uses this layout must pass:
    title       (required) — shown in the browser tab and used by SEO
    description (optional) — shown in Google search snippets
                             defaults to a generic tagline if not provided
*/
interface Props {
  title: string;
  description?: string;
  locale?: SiteLocale;
  dir?: "ltr" | "rtl";
}

const {
  title,
  description = "Argo Navis – automations, websites, and campaigns that grow your business.",
  locale = "en",
  dir = locale === "he" ? "rtl" : "ltr",
} = Astro.props;

const siteUrl = import.meta.env.SITE ?? "https://argo-navis.net";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const canonicalPath = stripLocalePrefix(Astro.url.pathname);
const englishURL = new URL(withLocale(canonicalPath, "en"), siteUrl);
const hebrewURL = new URL(withLocale(canonicalPath, "he"), siteUrl);
---

<!doctype html>
<html lang={locale} dir={dir} class="scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary meta -->
    <title>{title} | Argo Navis</title>
    <meta name="description" content={description} />

    <!--
      CANONICAL URL — tells Google which URL is the "real" version of
      this page. Prevents duplicate content issues if the same page
      is reachable via multiple URLs.
    -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={englishURL} />
    <link rel="alternate" hreflang="he" href={hebrewURL} />
    <link rel="alternate" hreflang="x-default" href={englishURL} />

    <!--
      OPEN GRAPH — controls how the page looks when shared on
      LinkedIn, Slack, WhatsApp, etc.
      og:title and og:description default to the same values above.
      og:image should be a 1200×630 px image — swap the path below.
    -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={`${title} | Argo Navis`} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={`${siteUrl}/og-image.png`} />

    <!--
      FONT — Inter loaded from Google Fonts.
      To swap the font: change the family name in both the link URL
      and the --font-sans variable in global.css.
      display=swap prevents invisible text while the font loads.
    -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark light" />
    <script is:inline>
      (() => {
        const key = "argo-theme";
        const html = document.documentElement;
        const stored = localStorage.getItem(key);
        if (stored === "light" || stored === "dark") {
          html.setAttribute("data-theme", stored);
          return;
        }
        const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;
        html.setAttribute("data-theme", prefersLight ? "light" : "dark");
      })();
    </script>
  </head>

  <body class="min-h-screen bg-surface-950 text-text-primary antialiased">

    <!-- Navigation sits at the very top of every page -->
    <Navigation locale={locale} />

    <!--
      <slot /> is the placeholder for each page's unique content.
      When a page does <Layout title="...">..page html...</Layout>,
      everything inside the tags replaces this slot.
    -->
    <main>
      <slot />
    </main>

    <!-- Footer sits at the very bottom of every page -->
    <Footer locale={locale} />

  </body>
</html>
