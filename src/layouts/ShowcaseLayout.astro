---
import Layout from "./Layout.astro";

/*
  PROPS — every showcase sub-page passes these in.

    title        — page title (browser tab + SEO)
    description  — meta description (Google snippet)
    service      — which service this belongs to ("Automations" / "Websites" / "Campaigns")
    serviceHref  — link back to the parent service page
    headline     — big h1 at the top of the case study
    subheadline  — one sentence under the h1
    metric1/2/3  — three key results shown as large stats
                   shape: { value: "3×", label: "faster onboarding" }
    tags         — technology tags shown as pills
*/
interface Metric { value: string; label: string; }

interface Props {
  title:        string;
  description?: string;
  service:      string;
  serviceHref:  string;
  headline:     string;
  subheadline:  string;
  metric1:      Metric;
  metric2:      Metric;
  metric3:      Metric;
  tags:         string[];
}

const {
  title, description,
  service, serviceHref,
  headline, subheadline,
  metric1, metric2, metric3,
  tags,
} = Astro.props;
---

<Layout title={title} description={description}>

  <!-- Back breadcrumb -->
  <div class="bg-surface-950 px-6 pt-10">
    <div class="mx-auto max-w-4xl">
      <a
        href={serviceHref}
        class="inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-text-primary"
      >
        <svg class="icon-chevron h-4 w-4 rotate-180 rtl:rotate-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to {service}
      </a>
    </div>
  </div>

  <!-- Header -->
  <header class="bg-surface-950 px-6 pb-16 pt-10 text-center">
    <div class="mx-auto max-w-3xl">

      <!-- Service badge -->
      <span class="mb-4 inline-block rounded-full border border-brand-500/30 bg-brand-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-brand-300">
        {service}
      </span>

      <h1 class="text-3xl font-extrabold leading-tight text-text-primary md:text-5xl">
        {headline}
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-text-muted">{subheadline}</p>

      <!-- Tags -->
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        {tags.map(tag => (
          <span class="rounded-md bg-surface-800 px-3 py-1 text-xs text-text-muted">{tag}</span>
        ))}
      </div>
    </div>
  </header>

  <!--
    KEY METRICS BAR — three big numbers that instantly communicate results.
    Change metric1/2/3 props on each showcase page to match the project.
  -->
  <div class="border-y border-border-subtle bg-surface-900 px-6 py-10">
    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-8 text-center sm:grid-cols-3 sm:gap-6">
      {[metric1, metric2, metric3].map(m => (
        <div>
          <p class="text-2xl font-extrabold text-text-primary sm:text-3xl md:text-4xl">{m.value}</p>
          <p class="mt-1 text-sm text-text-muted">{m.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!--
    BODY CONTENT — each showcase page puts its own sections here via <slot>.
      default slot  → the full article content
      cta           → optional CTA section (e.g. ContactForm) rendered inside <main>
  -->
  <article class="bg-surface-950 px-6 py-20">
    <div class="mx-auto max-w-3xl space-y-16">
      <slot />
    </div>
  </article>

  <slot name="cta" />

</Layout>
